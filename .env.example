XIAOMI_COUNTRY=ru
XIAOMI_DID=YOUR_DEVICE_DID
XIAOMI_MODEL=xiaomi.vacuum.d109gl
XIAOMI_VOICE_SIID=15
XIAOMI_VOICE_INSTALL_AIID=1
XIAOMI_VOICE_STATUS_AIID=2
# Optional captured Mi Home request saved inside this folder:
XIAOMI_SESSION_FILE=./state/captured_mihome_session.json
# Android-free browser-assisted login writes this file:
XIAOMI_CLOUD_AUTH_FILE=./state/cloud_auth.json
# Password login is a fallback when no captured session exists.
# XIAOMI_USER=mail@example.com
# XIAOMI_PASSWORD=change-me
# Optional local status queries only; deployment itself uses cloud action.
# XIAOMI_ROBOT_TOKEN=32_hex_characters
